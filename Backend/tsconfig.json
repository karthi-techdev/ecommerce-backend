{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // "moduleResolution": "node",
